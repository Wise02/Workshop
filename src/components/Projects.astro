---
// src/components/Projects.astro
import projects from '../data/projects.json';
---
<section id="projects" class="section projects">
  <div class="container">
    <p class="section-label">[ PROJECTS ]</p>
    <h2 class="section-title">ARSENAL</h2>

    <div class="projects-grid">
      {projects.map((p, i) => (
        <a
          href={p.url}
          target="_blank"
          rel="noopener noreferrer"
          class="project-card reveal"
          style={`animation-delay: ${i * 80}ms`}
        >
          <div class="card-top">
            <h3 class="card-title">{p.title}</h3>
            <span class="card-arrow">↗</span>
          </div>
          <p class="card-desc">{p.description}</p>
          <div class="card-tags">
            {p.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </a>
      ))}
    </div>

    <div class="reveal see-all">
      <a
        href="https://github.com/Wise02"
        target="_blank"
        rel="noopener noreferrer"
        class="btn"
      >
        [ SEE ALL ON GITHUB → ]
      </a>
    </div>
  </div>
</section>

<style>
  .projects { background: var(--void); }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    padding: 24px;
    border-radius: 2px;
    transition: border-color 200ms ease, transform 200ms ease;
    text-decoration: none;
  }
  .project-card:hover {
    border-color: var(--blood);
    transform: translateY(-4px);
  }

  .card-top { display: flex; justify-content: space-between; align-items: center; }
  .card-title { font-family: var(--font-display); font-size: 22px; letter-spacing: 2px; color: var(--blood); }
  .card-arrow { font-size: 18px; color: var(--muted); transition: color 200ms ease; }
  .project-card:hover .card-arrow { color: var(--blood); }

  .card-desc { font-size: 13px; color: var(--muted); line-height: 1.7; flex: 1; }
  .card-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .see-all { margin-top: 8px; }

  @media (max-width: 480px) {
    .projects-grid { grid-template-columns: 1fr; }
  }
</style>
