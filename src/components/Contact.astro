---
// src/components/Contact.astro
const EMAIL = 'betai1357@gmail.com';
---
<section id="contact" class="section contact">
  <div class="container">
    <p class="section-label">[ CONTACT ]</p>
    <h2 class="section-title">REACH OUT</h2>

    <div class="contact-card reveal">
      <p class="contact-prompt">WISE@WORKSHOP:~$ cat contact.txt</p>

      <div class="contact-links">
        <div class="contact-row" id="email-row" data-email={EMAIL} role="button" tabindex="0" aria-label="Copy email address">
          <span class="contact-icon">✉</span>
          <span class="contact-label">EMAIL</span>
          <span class="contact-value" id="email-display">{EMAIL}</span>
          <span class="contact-hint">[click to copy]</span>
        </div>

        <a class="contact-row" href="https://github.com/Wise02" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon">⌥</span>
          <span class="contact-label">GITHUB</span>
          <span class="contact-value">Wise02</span>
          <span class="contact-hint">↗</span>
        </a>

        <a class="contact-row" href="https://www.linkedin.com/in/itay-ben-adert/" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon">◈</span>
          <span class="contact-label">LINKEDIN</span>
          <span class="contact-value">Itay Ben-Adert</span>
          <span class="contact-hint">↗</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--surface); }

  .contact-card {
    background: var(--elevated);
    border: 1px solid var(--border);
    border-left: 3px solid var(--blood);
    padding: 40px;
    border-radius: 2px;
    max-width: 640px;
  }
  .contact-prompt { font-size: 11px; letter-spacing: 2px; color: var(--blood); margin-bottom: 28px; }
  .contact-links { display: flex; flex-direction: column; gap: 0; }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 12px;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: background 150ms ease;
    border-radius: 2px;
  }
  .contact-row:last-child { border-bottom: none; }
  .contact-row:hover { background: rgba(255, 32, 32, 0.06); }

  .contact-icon { font-size: 14px; color: var(--blood); width: 20px; flex-shrink: 0; }
  .contact-label { font-size: 10px; letter-spacing: 3px; color: var(--muted); width: 80px; flex-shrink: 0; }
  .contact-value { font-size: 13px; color: var(--text); flex: 1; }
  .contact-hint { font-size: 11px; color: var(--muted); letter-spacing: 1px; }

  #email-row { cursor: pointer; }

  @media (max-width: 640px) {
    .contact-card { padding: 24px 16px; }
    .contact-label { display: none; }
  }
</style>

<script>
  const row     = document.getElementById('email-row')!;
  const display = document.getElementById('email-display')!;
  const email   = row.dataset.email!;

  function copyEmail() {
    navigator.clipboard.writeText(email).then(() => {
      const original = display.textContent;
      display.textContent = '[ COPIED! ]';
      display.style.color = 'var(--blood)';
      setTimeout(() => {
        display.textContent = original;
        display.style.color = '';
      }, 1500);
    });
  }

  row.addEventListener('click', copyEmail);
  row.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') copyEmail();
  });
</script>
