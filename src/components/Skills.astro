---
// src/components/Skills.astro
import skills from '../data/skills.json';
---
<section id="skills" class="section skills">
  <div class="container">
    <p class="section-label">[ BACKGROUND ]</p>
    <h2 class="section-title">BACKGROUND</h2>

    <!-- Education -->
    <div class="reveal edu-block">
      <p class="block-label">WISE@WORKSHOP:~$ cat education.txt</p>
      <div class="entries-list">
        {skills.education.map(edu => (
          <div class="entry-card">
            <div class="entry-top">
              <span class="entry-title">{edu.institution}</span>
              <span class="entry-period">{edu.period}</span>
            </div>
            <p class="entry-sub">{edu.degree}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Experience -->
    <div class="reveal exp-block">
      <p class="block-label">WISE@WORKSHOP:~$ cat experience.txt</p>
      <div class="entries-list">
        {skills.experience.map(job => (
          <div class="entry-card">
            <div class="entry-top">
              <span class="entry-title">{job.title} — <span class="entry-company">{job.company}</span></span>
              <span class="entry-period">{job.period}</span>
            </div>
            <ul class="entry-bullets">
              {job.highlights.map(h => <li>{h}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Technical Skills -->
    <div class="reveal skills-block">
      <p class="block-label">WISE@WORKSHOP:~$ cat skills.txt</p>
      <div class="skills-grid">
        {Object.entries(skills.skills).map(([category, items]) => (
          <div class="skill-category">
            <p class="category-label">{category}</p>
            <div class="tags-row">
              {items.map(item => <span class="tag">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  .skills { background: var(--surface); }

  .block-label {
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--blood);
    margin-bottom: 20px;
  }

  /* Shared list */
  .entries-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 800px;
  }

  .entry-card {
    background: var(--elevated);
    border: 1px solid var(--border);
    border-left: 3px solid var(--blood);
    padding: 16px 20px;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .entry-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px;
  }

  .entry-title {
    font-size: 13px;
    color: var(--text);
    letter-spacing: 1px;
    font-weight: 700;
  }

  .entry-company {
    font-weight: 400;
    color: var(--muted);
  }

  .entry-period {
    font-size: 11px;
    color: var(--blood);
    letter-spacing: 1px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .entry-sub {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.5px;
  }

  .entry-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 0;
  }

  .entry-bullets li {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.6;
    padding-left: 14px;
    position: relative;
  }

  .entry-bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--blood);
    font-size: 10px;
  }

  /* Blocks spacing */
  .edu-block  { margin-bottom: 48px; }
  .exp-block  { margin-bottom: 48px; }
  .skills-block { margin-bottom: 48px; }

  /* Skills grid */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .skill-category {
    background: var(--elevated);
    border: 1px solid var(--border);
    border-left: 3px solid var(--blood);
    padding: 20px 24px;
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .category-label {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--blood);
  }

  .tags-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  @media (max-width: 640px) {
    .entry-top { flex-direction: column; }
    .skills-grid { grid-template-columns: 1fr; }
  }
</style>
