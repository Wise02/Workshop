---
// src/components/Hero.astro
---
<section id="hero" class="hero">
  <canvas id="matrix-bg" aria-hidden="true"></canvas>

  <div class="hero-inner container">
    <p class="hero-prompt reveal">WISE@WORKSHOP:~$ whoami</p>
    <h1 class="hero-name">
      <span id="scramble-target" data-text="WISE'S">WISE'S</span>
    </h1>
    <p class="hero-sub reveal">WORKSHOP</p>
    <div class="hero-divider reveal"></div>
    <p class="hero-tagline reveal">
      IT Specialist &nbsp;·&nbsp; Sysadmin &nbsp;·&nbsp; Cybersecurity
    </p>
    <div class="hero-actions reveal">
      <a href="#about"    class="btn">[ ABOUT ME ]</a>
      <a href="#projects" class="btn btn--filled">[ PROJECTS ]</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
    overflow: hidden;
  }
  #matrix-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  /* Gradient fade at bottom of hero — sits above canvas, below content */
  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35%;
    background: linear-gradient(to bottom, transparent, #050505);
    z-index: 0;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding: 80px 24px;
  }
  .hero-prompt {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 3px;
    color: var(--blood);
    margin-bottom: 12px;
  }
  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(72px, 14vw, 160px);
    letter-spacing: 6px;
    color: var(--text);
    line-height: 0.9;
  }
  .hero-sub {
    font-family: var(--font-display);
    font-size: clamp(48px, 9vw, 100px);
    letter-spacing: 6px;
    color: var(--blood);
    line-height: 1;
    margin-top: 4px;
  }
  .hero-divider {
    width: 60px; height: 2px;
    background: var(--blood);
    margin: 32px 0;
  }
  .hero-tagline {
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 2px;
    margin-bottom: 40px;
  }
  .hero-actions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
</style>

<script>
  // ── Matrix Rain ────────────────────────────────
  const canvas = document.getElementById('matrix-bg') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  const FONT_SIZE = 14;
  const CHARS = 'アイウエオカキクケコサシスセソタチツテトナニヌネノハヒフヘホABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';
  let drops: number[] = [];

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const cols = Math.floor(canvas.width / FONT_SIZE);
    drops = Array.from({ length: cols }, () => Math.random() * -50);
  }

  function draw() {
    ctx.fillStyle = 'rgba(5, 5, 5, 0.06)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    drops.forEach((y, i) => {
      const char = CHARS[Math.floor(Math.random() * CHARS.length)];
      const x = i * FONT_SIZE;

      ctx.fillStyle = '#ff4040';
      ctx.font = `bold ${FONT_SIZE}px 'JetBrains Mono', monospace`;
      ctx.fillText(char, x, y * FONT_SIZE);

      ctx.fillStyle = '#8b0000';
      ctx.font = `${FONT_SIZE}px 'JetBrains Mono', monospace`;

      if (y * FONT_SIZE > canvas.height && Math.random() > 0.975) {
        drops[i] = 0;
      }
      drops[i]++;
    });
  }

  resize();
  window.addEventListener('resize', resize, { passive: true });
  setInterval(draw, 50);

  // ── Text Scramble ──────────────────────────────
  const SCHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&';

  function scramble(el: HTMLElement, finalText: string) {
    let iteration = 0;
    const totalFrames = finalText.length * 4;
    const id = setInterval(() => {
      el.textContent = finalText
        .split('')
        .map((char, i) => {
          if (char === ' ' || char === "'") return char;
          if (i < Math.floor(iteration / 4)) return char;
          return SCHARS[Math.floor(Math.random() * SCHARS.length)];
        })
        .join('');
      if (iteration >= totalFrames) {
        el.textContent = finalText;
        clearInterval(id);
      }
      iteration++;
    }, 30);
  }

  const target = document.getElementById('scramble-target') as HTMLElement;
  const finalText = target.dataset.text ?? target.textContent ?? '';
  target.textContent = '';

  setTimeout(() => {
    scramble(target, finalText);
    document.querySelectorAll('.hero .reveal').forEach(el => {
      setTimeout(() => el.classList.add('visible'), 400);
    });
  }, 300);
</script>
